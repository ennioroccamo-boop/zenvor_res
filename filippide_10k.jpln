upero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 40: Swing frontale della gamba (per gamba, alternata)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Oscillazione controllata avanti-indietro della gamba tesa. Aumenta progressivamente l'ampiezza.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 40: Swing laterale della gamba (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Oscillazione laterale della gamba tesa. Apre l'anca.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 30: Affondo con rotazione del busto (per lato)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Affondo frontale, ruota il busto verso il ginocchio avanzato. Apre anca e torace.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 30: Hip circle — rotazioni dell'anca (per lato)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Piedi larghi, cerchi ampi con il bacino. 5 orario + 5 antiorario per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 20: Skipping basso (sul posto)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Ginocchia all'altezza del bacino, passo veloce. Attiva il pattern neuromuscolare della corsa.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 20: Calciata dietro — butt kicks (sul posto)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1