ero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"C: 30: Skipping alto con braccia attive (su 20 metri)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Frequenza massima, ginocchia oltre il bacino, braccia a 90°. Migliora la cadenza.\", \"recupero\": {\"serie\": 30, \"esercizio\": 60, \"circuitoInterno\": 0, \"circuitoGiro\": 90}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"C: 30: Calciata indietro veloce — fast butt kicks (su 20 metri)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Velocità massima. Il tallone deve sfiorare il gluteo il più rapidamente possibile.\", \"recupero\": {\"serie\": 30, \"esercizio\": 60, \"circuitoInterno\": 0, \"circuitoGiro\": 90}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"C: 30: Skipping basso con enfasi sul contatto (su 20 metri)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Focus: il piede tocca terra SOTTO il baricentro, non davanti. Riduce l'overstriding.\", \"recupero\": {\"serie\": 30, \"esercizio\": 60, \"circuitoInterno\": 0, \"circuitoGiro\": 90}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"C: 20: Strides — allungate progressive (80 metri)\", \"serie\": 4, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Parti lentamente, accelera fino al 90% nei 40 metri centrali, poi decelera. Controllo della meccanica ad alta velocità.\", \"recupero\": {\"serie\": 60, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"C: 20: Accelerazione in salita (30 metri, se disponibile)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Sprint al 90-95% in salita. Obbliga alla corretta meccanica: busto in avanti, spinta del piede, ginocchio alto.\", \"recupero\": {\"serie\": 60, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"D: Squat monopodalico — pistol con minima assistenza (per gamba)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"5\", \"note\": \"Assistenza leggera (due dita su una sedia). Progressione dal 5K: riduci assistenza ogni settimana.\", \"recupero\": {\"serie\": 30, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"D: Hip Thrust monopodalico con sacco/zaino 5-8 kg (per gamba)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"12\", \"note\": \"Carico leggero. Pausa 1 secondo in alto con contrazione massima del gluteo.\", \"recupero\": {\"serie\": 30, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"D: Calf raise eccentrico su scalino (per gamba)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"15\", \"note\": \"Sali con due gambe, scendi con una in 4 secondi. Prevenzione achillea.\", \"recupero\": {\"serie\": 30, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"E: Ponte glutei monopodalico con piede su rialzo (per lato)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"12\", \"note\": \"Piede elevato su panca. ROM maggiore, più stimolo sul gluteo.\", \"recupero\": {\"serie\": 30, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"E: Dead Bug con peso leggero (per lato)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"10\", \"note\": \"Schiena a terra, tieni un manubrio leggero (2-4 kg) con il braccio esteso. Aumenta la richiesta sul core.\", \"recupero\": {\"serie\": 30, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"E: Copenhagen plank (per lato)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"8\", \"note\": \"Fianco a terra, piede superiore su panca, solleva il corpo. Protegge adduttori e inguine.\", \"recupero\": {\"serie\": 30, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"G: Step up esplosivo con ginocchio alto (per gamba)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"10\", \"note\": \"Sali sulla panca esplosivamente, ginocchio opposto oltre il bacino al picco.\", \"recupero\": {\"serie\": 30, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"G: Affondi camminati con manubri (20 metri)\", \"serie\": 3, \"um\": \"kg\", \"quantita\": \"8\", \"note\": \"Affondi in avanzamento con un manubrio per mano (4-8 kg). Busto eretto.\", \"recupero\": {\"serie\": 30, \"esercizio\": 90, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"carico\", \"target_unit\": \"ripetizioni\", \"target_value\": 8}, {\"descrizione\": \"B: 45: Stretching quadricipiti (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"In piedi, tallone al gluteo, ginocchio chiuso. 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching femorali — piega in avanti (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Una gamba avanzata sul tallone, busto in avanti. 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching ileopsoas — affondo basso (per lato)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Affondo basso, ginocchio posteriore a terra, bacino avanti e in basso. 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching polpaccio — gastrocnemio (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Mani al muro, gamba posteriore tesa, tallone a terra. 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching polpaccio — soleo (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Stessa posizione, piega leggermente il ginocchio posteriore. 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 60: Stretching piriforme — figura 4 da seduti\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Seduta, incrocia la caviglia sul ginocchio opposto, inclina il busto in avanti. 60 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching IT Band — incrocio laterale (per lato)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"In piedi, incrocia le gambe, inclina il busto lateralmente verso la gamba posteriore.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 60: Stretching schiena — posizione del bambino\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"In ginocchio, braccia tese in avanti, fronte a terra. Decomprime la colonna dopo le uscite lunghe.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}]}, {\"nomeSessione\": \"CICLO1.Fartlek.S01-02.C_Sabato\", \"sport\": \"Running\", \"esercizi\": [{\"descrizione\": \"A: 30: Cerchi delle caviglie (per piede, alternati)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Ruota la caviglia 10 volte in senso orario e 10 antiorario per piede.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 40: Swing frontale della gamba (per gamba, alternata)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Oscillazione controllata avanti-indietro della gamba tesa. Aumenta progressivamente l'ampiezza.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 40: Swing laterale della gamba (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Oscillazione laterale della gamba tesa. Apre l'anca.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 30: Affondo con rotazione del busto (per lato)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Affondo frontale, ruota il busto verso il ginocchio avanzato. Apre anca e torace.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 30: Hip circle — rotazioni dell'anca (per lato)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Piedi larghi, cerchi ampi con il bacino. 5 orario + 5 antiorario per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 20: Skipping basso (sul posto)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Ginocchia all'altezza del bacino, passo veloce. Attiva il pattern neuromuscolare della corsa.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 20: Calciata dietro — butt kicks (sul posto)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Tallone che tocca il gluteo alternando le gambe. Riscalda i femorali.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"F: 600: Riscaldamento — corsa lenta 10 minuti\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"10 minuti a passo molto lento prima del fartlek. Il fartlek richiede un riscaldamento adeguato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"G: 60: Accelerazione fartlek — 1 minuto veloce\", \"serie\": 5, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"FARTLEK C1 S1-2: 5×(1' veloce / 2' lento). Ritmo 'veloce': più veloce dei tuoi 5 km, non uno sprint. Il fartlek si fa sempre senza fermarsi.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"G: 120: Corsa lenta di recupero\", \"serie\": 5, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"2 minuti di trotterellata. Non camminata: la continuità è parte dell'allenamento.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 120}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"Defaticamento — corsa lenta 5 minuti\", \"serie\": 1, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"5 minuti di corsa lentissima. Porta la frequenza cardiaca sotto 130 bpm.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}, \"exercise_mode\": \"misura\"}, {\"descrizione\": \"B: 45: Stretching quadricipiti (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"In piedi, tallone al gluteo, ginocchio chiuso. 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"c