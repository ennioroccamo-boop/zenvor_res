ise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 30: Hip circle (rotazioni dell'anca, per lato)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Piedi larghi, mani sui fianchi, disegna cerchi ampi con il bacino. 5 in senso orario, 5 antiorario per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 20: Skipping basso (sul posto)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Ginocchia all'altezza del bacino, passo veloce. Attiva il pattern neuromuscolare della corsa.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 20: Calciata dietro (sul posto)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Tallone che tocca il gluteo alternando le gambe a ritmo crescente. Riscalda i femorali.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"Riscaldamento: camminata veloce 5 minuti\", \"serie\": 1, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"5 minuti.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}, \"exercise_mode\": \"misura\"}, {\"descrizione\": \"H: 600: Corsa leggera\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Settimane 7-8: 10 minuti di corsa. L'uscita lunga supera sempre la sessione martedì. Questo è il giorno del volume, non della velocità.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 60}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"H: 60: Camminata veloce (recupero)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"1 minuto di camminata. Totale: 33 minuti di lavoro.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 60}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"Defaticamento: camminata lenta 5 minuti\", \"serie\": 1, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"5 minuti.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}, \"exercise_mode\": \"misura\"}, {\"descrizione\": \"B: 45: Stretching quadricipiti (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"In piedi, tallone al gluteo, ginocchio chiuso. Mantieni 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching femorali — piega in avanti (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Una gamba avanzata sul tallone, gamba posteriore leggermente flessa, busto in avanti. 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching ileopsoas — affondo basso (per lato)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Affondo basso, ginocchio posteriore a terra, bacino in avanti e in basso. Il muscolo più teso nei runner. 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching polpaccio — gastrocnemio (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Mani al muro, gamba posteriore tesa, tallone a terra. 45 secondi per lato.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching polpaccio — soleo (per gamba)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Stessa posizione ma piega leggermente il ginocchio posteriore. Arriva al muscolo più profondo.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 60: Stretching piriforme — figura 4 da seduti\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"Seduta, incrocia una caviglia sul ginocchio opposto, inclina il busto in avanti. 60 secondi per lato. Fondamentale per prevenire la sindrome del piriforme.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"B: 45: Stretching IT Band — incrocio laterale (per lato)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"In piedi, incrocia le gambe, inclina il busto lateralmente verso la gamba posteriore. Previene il dolore laterale al ginocchio.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}]}, {\"nomeSessione\": \"CICLO1.UscitaLunga.S09.C_Domenica_25min\", \"sport\": \"Running\", \"esercizi\": [{\"descrizione\": \"A: 30: Cerchi delle caviglie (per piede, alternati)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"In piedi su un piede, ruota la caviglia 10 volte in senso orario e 10 antiorario. Poi cambia.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 40: Swing frontale della gamba (per gamba, alternata)\", \"serie\": 1, \"um\": \"n.\", \"quantita\": \"1\", \"note\": \"In piedi, oscillazione controllata avanti-indietro della gamba tesa. Aumenta progressivamente l'ampiezza.\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 0, \"circuitoGiro\": 0}, \"exercise_mode\": \"conteggio\"}, {\"descrizione\": \"A: 40: Swing laterale della gamba (per gamba)\", \"serie\": 1, \"um\": \"