{"zenvor_export":"plan","version":1,"exportedAt":"2026-06-10T13:42:38.685Z","plan":{"id":"plan_20260610_29a7","name":"Nereo","date":"2026-06-10","type":"training_only","content":"<!DOCTYPE html>\n<html lang=\"it\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Nereo – Scivola più lontano, con meno fatica</title>\n    <style>\n        body { font-family: Arial, sans-serif; line-height: 1.4; color: #111; max-width: 1024px; margin: 0 auto; padding: 20px; background-color: #ffffff; }\n        header { border-bottom: 3px solid #111; padding-bottom: 15px; margin-bottom: 30px; }\n        h1 { font-size: 26px; text-transform: uppercase; margin: 0 0 5px 0; letter-spacing: -0.5px; }\n        h2 { font-size: 16px; font-weight: normal; text-transform: uppercase; margin: 0 0 15px 0; color: #444; }\n        h3 { font-size: 16px; text-transform: uppercase; margin: 25px 0 10px 0; padding-left: 8px; border-left: 4px solid #111; background-color: #f9f9f9; padding-top: 4px; padding-bottom: 4px; }\n        h4 { font-size: 14px; text-transform: uppercase; margin: 15px 0 5px 0; color: #0056b3; }\n        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 13px; }\n        th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }\n        th { background-color: #f2f2f2; font-weight: bold; text-transform: uppercase; font-size: 12px; }\n        .profile-box { background-color: #f9f9f9; border: 1px solid #ddd; padding: 15px; margin-bottom: 25px; font-size: 13px; }\n        .profile-box ul { margin: 5px 0 0 0; padding-left: 20px; }\n        .profile-box li { margin-bottom: 4px; }\n        a { color: #0056b3; text-decoration: none; }\n        a:hover { text-decoration: underline; }\n        @media print {\n            body { max-width: 100%; padding: 0; margin: 0; }\n        }\n    </style>\n</head>\n<body>\n\n<header>\n    <h1>Nereo – Scivola più lontano, con meno fatica</h1>\n    <h2>Programma Integrato di Nuoto di Fondo ed Efficienza Idrodinamica</h2>\n</header>\n\n<div class=\"profile-box\">\n    <strong>Riepilogo Profilo Atleta e Obiettivi Finali Realistici:</strong>\n    <ul>\n        <li><strong>Pre-requisito di partenza:</strong> Capacità di nuotare a stile libero una distanza minima di almeno 50 metri continuativi.</li>\n        <li><strong>Fattore limitante iniziale:</strong> Affanno precoce, inefficienza posturale con affondamento del bacino, eccessivo attrito idrodinamico.</li>\n        <li><strong>Obiettivo finale realistico:</strong> Nuotare per almeno 1 km continuo senza fermarsi, acquisendo una nuotata decontratta ed efficiente che massimizza la velocità di crociera e minimizza lo sforzo percepito.</li>\n    </ul>\n</div>\n\n<section data-ciclo=\"1\" data-ciclo-nome=\"CICLO 1: L'Assetto e il Fiato\">\n    <h3>CICLO 1: L'Assetto e il Fiato (Settimane 1-4)</h3>\n    \n    <div data-tipo=\"obiettivi\" data-ciclo=\"1\">\n        <p><strong>Obiettivi Intermedi Misurabili:</strong> Nuotare una distanza totale di 200 metri frazionati (4x50m) in totale decontrazione, stabilizzando la respirazione bilaterale ogni 3 bracciate ed eliminando l'affanno precoce grazie all'isolamento posturale del Pull Buoy.</p>\n    </div>\n    \n    <div data-tipo=\"tabella-settimanale\" data-ciclo=\"1\">\n        <table>\n            <thead>\n                <tr>\n                    <th>Giorno</th>\n                    <th>Sport</th>\n                    <th>Orario</th>\n                    <th>Tipo Sessione</th>\n                    <th>Durata</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <td>Lunedì</td>\n                    <td>Nuoto in vasca</td>\n                    <td>07:30</td>\n                    <td>CICLO1.Nuoto.01.IsolamentoAssetto (600m tot)</td>\n                    <td>45 min</td>\n                </tr>\n                <tr>\n                    <td>Mercoledì</td>\n                    <td>Ginnastica a corpo libero</td>\n                    <td>18:30</td>\n                    <td>CICLO1.GinnasticaACorpoLibero.01.HICT (2 Giri)</td>\n                    <td>20 min</td>\n                </tr>\n                <tr>\n                    <td>Venerdì</td>\n                    <td>Nuoto in vasca</td>\n                    <td>07:30</td>\n                    <td>CICLO1.Nuoto.02.ConsolidamentoFrazionato (600m tot)</td>\n                    <td>45 min</td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n    \n    <div data-tipo=\"sessioni-sport\" data-ciclo=\"1\" data-sport=\"Nuoto in vasca\">\n        <h4>Esercizi in Vasca - Lunedì (Sessione 1: Isolamento e Assetto)</h4>\n        <div data-tipo=\"tabella-esercizi\" data-ciclo=\"1\" data-sessione=\"CICLO1.Nuoto.01.IsolamentoAssetto\" data-sport=\"Nuoto in vasca\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Nome sessione</th>\n                        <th>Giorno</th>\n                        <th>Orario</th>\n                        <th>Esercizio / Fase</th>\n                        <th>Serie</th>\n                        <th>Rip./Durata</th>\n                        <th>U.M.</th>\n                        <th>Note tecniche</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>CICLO1.Nuoto.01.IsolamentoAssetto</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :100: Riscaldamento - Stile Libero blando</td>\n                        <td>1</td>\n                        <td>100</td>\n                        <td>metri</td>\n                        <td>Nuotata rilassata, focus sulla regolarità respiratoria iniziale.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.Nuoto.01.IsolamentoAssetto</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :25: Tecnico - Kick on Side (Gambe sul fianco)</td>\n                        <td>4</td>\n                        <td>25</td>\n                        <td>metri</td>\n                        <td>Effettuare solo battuta di gambe sul fianco. Alternare fianco destro e sinistro ad ogni vasca. Rec. 20\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.Nuoto.01.IsolamentoAssetto</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :50: Centrale - Stile Libero con Pull Buoy</td>\n                        <td>6</td>\n                        <td>50</td>\n                        <td>metri</td>\n                        <td>Isolamento del core e galleggiamento alto. Concentrarsi sulla respirazione bilaterale ogni 3 bracciate. Rec. 30\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.Nuoto.01.IsolamentoAssetto</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :100: Defaticamento - Dorso o Stile decontratto</td>\n                        <td>1</td>\n                        <td>100</td>\n                        <td>metri</td>\n                        <td>Nuotata leggerissima per abbassare la frequenza cardiaca e allungare la muscolatura.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n\n        <h4>Esercizi in Vasca - Venerdì (Sessione 2: Consolidamento Frazionato)</h4>\n        <div data-tipo=\"tabella-esercizi\" data-ciclo=\"1\" data-sessione=\"CICLO1.Nuoto.02.ConsolidamentoFrazionato\" data-sport=\"Nuoto in vasca\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Nome sessione</th>\n                        <th>Giorno</th>\n                        <th>Orario</th>\n                        <th>Esercizio / Fase</th>\n                        <th>Serie</th>\n                        <th>Rip./Durata</th>\n                        <th>U.M.</th>\n                        <th>Note tecniche</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>CICLO1.Nuoto.02.ConsolidamentoFrazionato</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :100: Riscaldamento - Stile Libero alternato a Dorso</td>\n                        <td>1</td>\n                        <td>100</td>\n                        <td>metri</td>\n                        <td>Attivazione generale e mobilità articolare in acqua.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.Nuoto.02.ConsolidamentoFrazionato</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :25: Tecnico - Sculling (Sensibilità acqua)</td>\n                        <td>4</td>\n                        <td>25</td>\n                        <td>metri</td>\n                        <td>Isolare la presa della mano avanzata senza spingere di forza. Rec. 20\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.Nuoto.02.ConsolidamentoFrazionato</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :100: Centrale - Ripetute Stile Libero (Postura e Fiato)</td>\n                        <td>4</td>\n                        <td>100</td>\n                        <td>metri</td>\n                        <td>Primi 50m eseguiti in Catch-Up Drill, successivi 50m Stile Libero completo decontratto. Rec. 35\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.Nuoto.02.ConsolidamentoFrazionato</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :100: Defaticamento - Stile Libero rilassatissimo</td>\n                        <td>1</td>\n                        <td>100</td>\n                        <td>metri</td>\n                        <td>Recupero attivo totale. Focus sullo scivolamento passivo.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </div>\n    \n    <div data-tipo=\"sessioni-sport\" data-ciclo=\"1\" data-sport=\"Ginnastica a corpo libero\">\n        <h4>Esercizi a Secco - Mercoledì (Sessione HICT)</h4>\n        <div data-tipo=\"tabella-esercizi\" data-ciclo=\"1\" data-sessione=\"CICLO1.GinnasticaACorpoLibero.01.HICT\" data-sport=\"Ginnastica a corpo libero\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Nome sessione</th>\n                        <th>Giorno</th>\n                        <th>Orario</th>\n                        <th>Esercizio</th>\n                        <th>Serie</th>\n                        <th>Rip./Durata</th>\n                        <th>U.M.</th>\n                        <th>Note tecniche</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Plank frontale isometrico</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Allineamento rigido testa-bacino-piedi. Fondamentale per mantenere il galleggiamento alto.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Squat a corpo libero</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Massimo numero di ripetizioni controllate. Focus su stabilità plantare e spinta simmetrica.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Lat Pulldown isometrico con asciugamano</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Trazionare l'asciugamano verso l'esterno con massima forza, simulando l'aggancio dell'acqua.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Bird-Dog alternato</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Estensione fluida braccio/gamba opposta per rinforzare la catena cinetica crociata posteriore.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Piegamenti facilitati (ginocchia a terra)</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Contare le ripetizioni. Gomiti stretti vicino ai fianchi per proteggere la cuffia dei rotatori.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Mobilità spalle extra-rotatori con asciugamano</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Tensione costante verso l'esterno per aprire il pettorale e facilitare il recupero aereo.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Plank laterale destro</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Mantenere il fianco alto. Sviluppa la stabilità lateralità necessaria per la rollata del busto.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Plank laterale sinistro</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Tenuta isometrica speculare per garantire simmetria posturale durante la respirazione.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Ponte glutei a terra</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Attivazione dinamica dei glutei con picco contrattile di 1 secondo per sostenere le gambe.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Rematore isometrico con asciugamano sotto i piedi</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Trazione continua massima tirando l'asciugamano verso l'ombelico, schiena dritta.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Superman short holds</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Sollevare petto e cosce da terra in modo controllato, tenuta di 2 secondi ad ogni ripetizione.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO1.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Circonduzioni spalle lente con elastico</td>\n                        <td>2</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Movimento di mobilità attiva molto lento e controllato per decontrarre il cingolo scapolare.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </div>\n</section>\n\n<section data-ciclo=\"2\" data-ciclo-nome=\"CICLO 2: Lo Scivolamento ed Efficienza\">\n    <h3>CICLO 2: Lo Scivolamento ed Efficienza (Settimane 5-8)</h3>\n    \n    <div data-tipo=\"obiettivi\" data-ciclo=\"2\">\n        <p><strong>Obiettivi Intermedi Misurabili:</strong> Raggiungere la capacità di nuotare un blocco continuo da 400 metri a ritmo costante, riducendo attivamente il numero di bracciate per vasca e memorizzando la battuta di gambe a 2 tempi.</p>\n    </div>\n    \n    <div data-tipo=\"tabella-settimanale\" data-ciclo=\"2\">\n        <table>\n            <thead>\n                <tr>\n                    <th>Giorno</th>\n                    <th>Sport</th>\n                    <th>Orario</th>\n                    <th>Tipo Sessione</th>\n                    <th>Durata</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <td>Lunedì</td>\n                    <td>Nuoto in vasca</td>\n                    <td>07:30</td>\n                    <td>CICLO2.Nuoto.01.TransizionePropulsione (900m tot)</td>\n                    <td>50 min</td>\n                </tr>\n                <tr>\n                    <td>Mercoledì</td>\n                    <td>Ginnastica a corpo libero</td>\n                    <td>18:30</td>\n                    <td>CICLO2.GinnasticaACorpoLibero.01.HICT (3 Giri)</td>\n                    <td>30 min</td>\n                </tr>\n                <tr>\n                    <td>Venerdì</td>\n                    <td>Nuoto in vasca</td>\n                    <td>07:30</td>\n                    <td>CICLO2.Nuoto.02.ConteggioBracciate (900m tot)</td>\n                    <td>50 min</td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n\n    <div data-tipo=\"sessioni-sport\" data-ciclo=\"2\" data-sport=\"Nuoto in vasca\">\n        <h4>Esercizi in Vasca - Lunedì (Sessione 1: Transizione Propulsione)</h4>\n        <div data-tipo=\"tabella-esercizi\" data-ciclo=\"2\" data-sessione=\"CICLO2.Nuoto.01.TransizionePropulsione\" data-sport=\"Nuoto in vasca\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Nome sessione</th>\n                        <th>Giorno</th>\n                        <th>Orario</th>\n                        <th>Esercizio / Fase</th>\n                        <th>Serie</th>\n                        <th>Rip./Durata</th>\n                        <th>U.M.</th>\n                        <th>Note tecniche</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>CICLO2.Nuoto.01.TransizionePropulsione</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :150: Riscaldamento - Stile Libero con focus rollata</td>\n                        <td>1</td>\n                        <td>150</td>\n                        <td>metri</td>\n                        <td>Nuotare alternando la sensibilità sui due fianchi.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.Nuoto.01.TransizionePropulsione</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :50: Tecnico - 6-3-6 Drill (Cambio fianco)</td>\n                        <td>4</td>\n                        <td>50</td>\n                        <td>metri</td>\n                        <td>Trovare la stabilità laterale prima di effettuare le 3 bracciate. Rec. 20\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.Nuoto.01.TransizionePropulsione</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :100: Centrale - Frazionato di Resistenza Posturale</td>\n                        <td>4</td>\n                        <td>100</td>\n                        <td>metri</td>\n                        <td>Mantenere una battuta di gambe a 2 tempi economica e costante. Rec. 30\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.Nuoto.01.TransizionePropulsione</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :150: Defaticamento - Dorso o Stile rilassato</td>\n                        <td>1</td>\n                        <td>150</td>\n                        <td>metri</td>\n                        <td>Decontrarre spalle e allungare la sbracciata.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n\n        <h4>Esercizi in Vasca - Venerdì (Sessione 2: Conteggio Bracciate)</h4>\n        <div data-tipo=\"tabella-esercizi\" data-ciclo=\"2\" data-sessione=\"CICLO2.Nuoto.02.ConteggioBracciate\" data-sport=\"Nuoto in vasca\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Nome sessione</th>\n                        <th>Giorno</th>\n                        <th>Orario</th>\n                        <th>Esercizio / Fase</th>\n                        <th>Serie</th>\n                        <th>Rip./Durata</th>\n                        <th>U.M.</th>\n                        <th>Note tecniche</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>CICLO2.Nuoto.02.ConteggioBracciate</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :150: Riscaldamento - Stile Libero progressivo</td>\n                        <td>1</td>\n                        <td>150</td>\n                        <td>metri</td>\n                        <td>Incremento graduale della frequenza, mantenendo l'allineamento.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.Nuoto.02.ConteggioBracciate</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :50: Tecnico - Catch-Up Drill alternato a Sculling</td>\n                        <td>4</td>\n                        <td>50</td>\n                        <td>metri</td>\n                        <td>25m Sculling + 25m Stile sovrapposto. Rec. 25\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.Nuoto.02.ConteggioBracciate</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :200: Centrale - Blocco di Scivolamento Idrodinamico</td>\n                        <td>2</td>\n                        <td>200</td>\n                        <td>metri</td>\n                        <td>Contare le bracciate nella seconda vasca di ogni 50m, cercando di ridurle. Rec. 40\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.Nuoto.02.ConteggioBracciate</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :150: Defaticamento - Nuotata blanda a piacere</td>\n                        <td>1</td>\n                        <td>150</td>\n                        <td>metri</td>\n                        <td>Massimo relax muscolare.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </div>\n    \n    <div data-tipo=\"sessioni-sport\" data-ciclo=\"2\" data-sport=\"Ginnastica a corpo libero\">\n        <h4>Esercizi a Secco - Mercoledì (Sessione HICT)</h4>\n        <div data-tipo=\"tabella-esercizi\" data-ciclo=\"2\" data-sessione=\"CICLO2.GinnasticaACorpoLibero.01.HICT\" data-sport=\"Ginnastica a corpo libero\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Nome sessione</th>\n                        <th>Giorno</th>\n                        <th>Orario</th>\n                        <th>Esercizio</th>\n                        <th>Serie</th>\n                        <th>Rip./Durata</th>\n                        <th>U.M.</th>\n                        <th>Note tecniche</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Plank frontale dinamico (oscillazioni avanti/dietro)</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Spostare il baricentro sulle punte dei piedi mimando l'allungamento in fase di sbracciata.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Affondi alternati posteriori</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Lavoro di stabilità monopodalica ed estensione dell'anca per stabilizzare il rollio.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Lat Pulldown dinamico con elastico alle spalle</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Trazione fluida attivando i grandi dorsali e stabilizzando le scapole in basso.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Bird-Dog statico tenuta isometrica alternata (15s+15s)</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Mantenere una linea orizzontale perfetta senza oscillazioni del bacino.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Piegamenti classici sulle braccia</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Forza di spinta del cingolo scapolare. Mantenere l'addome compatto.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Aperture a busto flesso con elastico</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Rinforzo dei deltoidi posteriori per un recupero aereo alto a gomito flesso.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Plank laterale destro con torsione del busto</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Ruotare il braccio libero sotto il costato e riallineare, coordinando la rollata.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Plank laterale sinistro con torsione del busto</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Esecuzione speculare per equilibrare la mobilità torsionale sui due lati.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Ponte glutei monopodale (15s destro / 15s sinistro)</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Massimo isolamento degli estensori dell'anca per un assetto rettilineo in acqua.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Rematore dinamico busto flesso con elastico</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Simulazione dinamica della fase attiva di trazione subacquea (fase di spinta finale).</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Nuotatore a terra (coordinazione braccia/gambe alternate)</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Movimenti alternati rapidi a pancia in giù, allenamento del timing neuromuscolare.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO2.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Stretching pettorali al muro in tenuta statica</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Allungamento e decontrazione profonda dei muscoli intrarotatori della spalla.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </div>\n</section>\n\n<section data-ciclo=\"3\" data-ciclo-nome=\"CICLO 3: La Transizione al Continuo\">\n    <h3>CICLO 3: La Transizione al Continuo (Settimane 9-12)</h3>\n    \n    <div data-tipo=\"obiettivi\" data-ciclo=\"3\">\n        <p><strong>Obiettivi Finali Realistici:</strong> Completare il test finale di 1.000 metri continui senza fermarsi in vasca da 25m, mantenendo il ritmo target costante (CSS) ed un'ottima fluidità ed efficienza posturale complessiva.</p>\n    </div>\n    \n    <div data-tipo=\"tabella-settimanale\" data-ciclo=\"3\">\n        <table>\n            <thead>\n                <tr>\n                    <th>Giorno</th>\n                    <th>Sport</th>\n                    <th>Orario</th>\n                    <th>Tipo Sessione</th>\n                    <th>Durata</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <td>Lunedì</td>\n                    <td>Nuoto in vasca</td>\n                    <td>07:30</td>\n                    <td>CICLO3.Nuoto.01.CondizionamentoPacing (1200m tot)</td>\n                    <td>55 min</td>\n                </tr>\n                <tr>\n                    <td>Mercoledì</td>\n                    <td>Ginnastica a corpo libero</td>\n                    <td>18:30</td>\n                    <td>CICLO3.GinnasticaACorpoLibero.01.HICT (3 Giri)</td>\n                    <td>30 min</td>\n                </tr>\n                <tr>\n                    <td>Venerdì</td>\n                    <td>Nuoto in vasca</td>\n                    <td>07:30</td>\n                    <td>CICLO3.Nuoto.02.TestFinaleContinuo (1200m tot)</td>\n                    <td>60 min</td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n\n    <div data-tipo=\"sessioni-sport\" data-ciclo=\"3\" data-sport=\"Nuoto in vasca\">\n        <h4>Esercizi in Vasca - Lunedì (Sessione 1: Condizionamento e Pacing)</h4>\n        <div data-tipo=\"tabella-esercizi\" data-ciclo=\"3\" data-sessione=\"CICLO3.Nuoto.01.CondizionamentoPacing\" data-sport=\"Nuoto in vasca\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Nome sessione</th>\n                        <th>Giorno</th>\n                        <th>Orario</th>\n                        <th>Esercizio / Fase</th>\n                        <th>Serie</th>\n                        <th>Rip./Durata</th>\n                        <th>U.M.</th>\n                        <th>Note tecniche</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>CICLO3.Nuoto.01.CondizionamentoPacing</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :200: Riscaldamento - Stile Libero sciolto</td>\n                        <td>1</td>\n                        <td>200</td>\n                        <td>metri</td>\n                        <td>Concentrazione sul ritmo respiratorio calmo.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.Nuoto.01.CondizionamentoPacing</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :100: Tecnico - Esercizi misti di sensibilità (Drills)</td>\n                        <td>2</td>\n                        <td>100</td>\n                        <td>metri</td>\n                        <td>50m 6-3-6 + 50m Catch-Up. Rec. 20\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.Nuoto.01.CondizionamentoPacing</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :600: Centrale - Piramide di Condizionamento Energetico</td>\n                        <td>1</td>\n                        <td>600</td>\n                        <td>metri</td>\n                        <td>Frazionato come: 100m + 200m + 200m + 100m a ritmo gara CSS costante. Rec. 30\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.Nuoto.01.CondizionamentoPacing</td>\n                        <td>Lunedì</td>\n                        <td>07:30</td>\n                        <td>: :200: Defaticamento - Dorso rilassato</td>\n                        <td>1</td>\n                        <td>200</td>\n                        <td>metri</td>\n                        <td>Fase finale di rilassamento muscolare completo.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n\n        <h4>Esercizi in Vasca - Venerdì (Sessione 2: Test Finale Continuo)</h4>\n        <div data-tipo=\"tabella-esercizi\" data-ciclo=\"3\" data-sessione=\"CICLO3.Nuoto.02.TestFinaleContinuo\" data-sport=\"Nuoto in vasca\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Nome sessione</th>\n                        <th>Giorno</th>\n                        <th>Orario</th>\n                        <th>Esercizio / Fase</th>\n                        <th>Serie</th>\n                        <th>Rip./Durata</th>\n                        <th>U.M.</th>\n                        <th>Note tecniche</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>CICLO3.Nuoto.02.TestFinaleContinuo</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :100: Riscaldamento - Stile Libero e attivazione</td>\n                        <td>1</td>\n                        <td>100</td>\n                        <td>metri</td>\n                        <td>Attivazione cardiaca e respiratoria minima per non accumulare acido lattico.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.Nuoto.02.TestFinaleContinuo</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :50: Tecnico - Sculling controllato</td>\n                        <td>2</td>\n                        <td>50</td>\n                        <td>metri</td>\n                        <td>Svegliare i recettori nervosi del palmo della mano. Rec. 15\".</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.Nuoto.02.TestFinaleContinuo</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :1000: Centrale - TEST 1.000 METRI CONTINUI</td>\n                        <td>1</td>\n                        <td>1000</td>\n                        <td>metri</td>\n                        <td>Nuotata continua a stile libero. Mantenere andatura costante, respirazione regolare, focus sul non accelerare nei primi 200 metri.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.Nuoto.02.TestFinaleContinuo</td>\n                        <td>Venerdì</td>\n                        <td>07:30</td>\n                        <td>: :50: Defaticamento - Nuotata leggerissima a piacere</td>\n                        <td>1</td>\n                        <td>50</td>\n                        <td>metri</td>\n                        <td>Scarico totale decontrattivo post-test.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </div>\n    \n    <div data-tipo=\"sessioni-sport\" data-ciclo=\"3\" data-sport=\"Ginnastica a corpo libero\">\n        <h4>Esercizi a Secco - Mercoledì (Sessione HICT)</h4>\n        <div data-tipo=\"tabella-esercizi\" data-ciclo=\"3\" data-sessione=\"CICLO3.GinnasticaACorpoLibero.01.HICT\" data-sport=\"Ginnastica a corpo libero\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Nome sessione</th>\n                        <th>Giorno</th>\n                        <th>Orario</th>\n                        <th>Esercizio</th>\n                        <th>Serie</th>\n                        <th>Rip./Durata</th>\n                        <th>U.M.</th>\n                        <th>Note tecniche</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Plank sulle mani con tocco spalla alternato</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Stabilizzazione del core in conditione di instabilità asimmetrica dinamica.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Jump Squat controllati</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Forza e reattività degli arti inferiori, utile per ottimizzare la spinta dal muro.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Trazioni orizzontali sotto il tavolo o con elastico forte</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Massimo reclutamento del grande dorsale per generare potenza nella trazione subacquea.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Hollow Body Hold (Barchetta isometricica)</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Schiacciare la zona lombare al suolo. Massima espressione di idrodinamica posturale.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Piegamenti sulle braccia con stop in basso di 2 secondi</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Aumento del tempo sotto tensione per incrementare la resistenza della catena anteriore.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Face Pull con elastico ancorato</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Rinforzo dei rotatori esterni e dei fissatori della scapola per la salute della spalla.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Plank laterale con sollevamento gamba superiore</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Lavoro avanzato per medio gluteo e obliqui dell'addome contro le forze d'inerzia.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: V-Ups facilitati (Tuck Crunches veloci)</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Forza addominale dinamica per mantenere compatto il baricentro in stato di affaticamento.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Burpees senza salto finale</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Mantenere un ritmo costante per allenare la gestione del debito d'ossigeno sistemico.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Trazione singola alternata con elastico (passo nuoto)</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Simulazione dinamica a secco del timing alternato di bracciata a ritmo gara.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Superman con estensione e circonduzione braccia</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>n.</td>\n                        <td>Lavoro isometrico lombare profondo accoppiato alla mobilità attiva degli arti superiori.</td>\n                    </tr>\n                    <tr>\n                        <td>CICLO3.GinnasticaACorpoLibero.01.HICT</td>\n                        <td>Mercoledì</td>\n                        <td>18:30</td>\n                        <td>A: 30: Posizione del bambino (Scarico Yoga)</td>\n                        <td>3</td>\n                        <td></td>\n                        <td>tempi</td>\n                        <td>Allungamento e rilassamento passivo della colonna e dei dorsali per favorire il recupero.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </div>\n</section>\n\n<section>\n    <h3>Capitolo Tecnico: Descrizione Esercizi in Vasca (Drills)</h3>\n    <p>Il nuoto di fondo richiede un'esecuzione impeccabile dei movimenti subacquei. Clicca sui link per studiare i video demonstrativi su YouTube prima di scendere in acqua:</p>\n    <ul>\n        <li>\n            <a id=\"link-drill-1\" href=\"https://www.youtube.com/watch?v=nugBV3KLkUA\" target=\"_blank\"><strong>Esercizio 1: Kick on Side (Gambe sul fianco)</strong></a><br>\n            <em>Descrizione tecnica:</em> Si nuota sul fianco effettuando esclusivamente la battuta di gambe. Il braccio inferiore è completamente teso in avanti a fungere da linea di scivolamento guidando la traiettoria, mentre l'altro braccio è rilassato lungo il fianco. La testa è ruotata verso il basso (sguardo fisso sul fondo della vasca) e ruota sull'asse longitudinale solo per respirare. Serve a stabilire il galleggiamento laterale e a comprendere che il nuoto efficiente avviene sui fianchi, riducendo drasticamente l'attrito frontale.\n        </li>\n        <li style=\"margin-top: 15px;\">\n            <a id=\"link-drill-2\" href=\"https://www.youtube.com/watch?v=JeluJHvClaE\" target=\"_blank\"><strong>Esercizio 2: Catch-Up Drill (Stile Sovrapposto)</strong></a><br>\n            <em>Descrizione tecnica:</em> Durante la nuotata a stile libero, il braccio teso in avanti attende che l'altro braccio esegua l'intera fase di trazione, spinta e recupero aereo. La bracciata successiva comincia solo quando la mano che recupera tocca fisso la mano ferma in avanti. Questo drill costringe l'atleta a mantenere una postura allungata, insegnando la fase di scivolamento idrodinamico e impedendo alla mano di cadere prematuramente perdendo la presa sull'acqua.\n        </li>\n        <li style=\"margin-top: 15px;\">\n            <a id=\"link-drill-3\" href=\"https://www.youtube.com/watch?v=e_vJzgW6zyU\" target=\"_blank\"><strong>Esercizio 3: 6-3-6 Drill (Cambio Fianco / 6-Kick Switch)</strong></a><br>\n            <em>Descrizione tecnica:</em> Variante evoluta del Kick on Side. L'atleta esegue 6 colpi di gambe in posizione laterale sul fianco destro, effettua poi 3 bracciate complete e fluide a stile libero per cambiare assetto, e si stabilizza sul fianco sinistro eseguendo altre 6 battute di gambe. Sviluppa perfettamente la coordinazione e la fluidità della rollata del busto mantenendo una linea d'allineamento stabile e indeformabile.\n        </li>\n        <li style=\"margin-top: 15px;\">\n            <a id=\"link-drill-4\" href=\"https://www.youtube.com/watch?v=fep0EwmlfKA\" target=\"_blank\"><strong>Esercizio 4: Sculling (Sensibilità dell'acqua)</strong></a><br>\n            <em>Descrizione tecnica:</em> Posizione a pancia in giù con le braccia distese in avanti e mani posizionate leggermente più ampie delle spalle. Si eseguono piccoli movimenti oscillatori laterali dei palmi ad inclinazione alternata (45 gradi), generando una portanza idrodinamica che fa avanzare leggermente il corpo. Questo esercizio isola la sensibilità del palmo e dell'avambraccio, insegnando ad \"agganciare\" l'acqua precocemente (Early Vertical Forearm).\n        </li>\n    </ul>\n</section>\n\n<section id=\"capitolo-mitologico\">\n    <h3>Note Culturali: L'Ispirazione dietro al Nome \"Nereo\"</h3>\n    <p><strong>Nereo (Nereus)</strong> è una divinità marina della mitologia greca, noto come il “Vecchio del Mare”. Considerato un dio primordiale, è celebrato per la sua saggezza, la capacità di profetizzare e il potere di mutare forma. Rappresenta gli aspetti benevoli e fecondi del mare, in contrasto con divinità più tempestose come Poseidone. Incarna il mare nella sua dimensione pacifica e generosa, in contrapposizione al suo volto distruttivo.</p>\n    <p>Questo programma porta il suo nome poiché mira a trasformare l'approccio con l'acqua: non una lotta contro le onde (volto tempestoso), bensì una sintonia fluida, decontratta e geometricamente perfetta con l'elemento liquido (dimensione pacifica ed efficiente).</p>\n</section>\n\n<div data-tipo=\"raccomandazioni\">\n    <h3>Raccomandazioni Alimentari, Esercizi a Terra e Recupero</h3>\n    \n    <p><strong>Raccomandazioni Alimentari e Idratazione:</strong><br>\n    Il nuoto consuma energia in modo silente anche a causa della termoregolazione in acqua. È fundamental consumare un pasto ricco di carboidrati a medio-basso indice glicemico (es. avena integrale, pane di segale o una banana) circa 1.5 o 2 ore prima della sessione in vasca per stabilizzare i livelli di glicogeno muscolare senza appesantire lo stomaco. Entro 45 minuti dal termine dell'allenamento (finestra anabolica), assumere carboidrati semplici e proteine a rapido assorbimento per riparare le fibre e accelerare il ripristino. Portare sempre una borraccia d'acqua a bordo vasca: sebbene lo stimolo della sete sia attenuato dall'ambiente acquatico, la sudorazione è elevata e la disidratazione causa una perdita immediata di efficienza contrattile muscolare.</p>\n    \n    <p><strong>Esercizi a Terra e Core Stability:</strong><br>\n    Il condizionamento a secco tramite i circuiti HICT del mercoledì ha lo scopo primario di stabilizzare la colonna e rinforzare i muscoli fissatori delle scapole. Un core debole provoca l'oscillazione incontrollata dei piedi e del bacino (effetto serpeggiamento), che aumenta del doppio l'attrito frontale inficiando l'efficienza. Eseguire gli esercizi di mobilità articolare e lo stretching profondo solo al termine delle sessioni in acqua e mai in forma statica prima dell'ingresso in vasca, per preservare la prontezza e la stiffness muscolare necessaria.</p>\n    \n    <p><strong>Strategie per il Giusto Recupero e Riposo:</strong><br>\n    L'adattamento idrodinamico e l'incremento della resistenza avvengono durante il sonno profondo (supercompensazione) tramite il rilascio dell'ormone GH. Garantire sempre 7-8 ore di riposo continuativo. Qualora si riscontrino segnali di affaticamento sistemico acuto o dolori persistenti alla cuffia dei rotatori, la sessione successiva deve essere convertita in una seduta di recupero attivo, focalizzandosi esclusivamente su nuotata blanda e sensibilità subacquea tramite l'esercizio di <a href=\"#link-drill-4\">Sculling</a>.</p>\n</div>\n\n<div id=\"training-sessions-json\" style=\"display:none\">\n{\n  \"infoProgramma\": {\n    \"nome\": \"Nereo / Nereus\",\n    \"riferimentoMitologico\": \"Nereus è una divinità marina della mitologia greca, noto come il 'Vecchio del Mare'. Considerato un dio primordiale, è celebrato per la sua saggezza, la capacità di profetizzare e il potere di mutare forma. Rappresenta gli aspetti benevoli e fecondi del mare, in contrasto con divinità più tempestose come Poseidone. Incarna il mare nella sua dimensiona pacifica e generosa, in contrapposizione al suo volto distruttivo.\"\n  },\n  \"sessioni\": [\n    {\n      \"nomeSessione\": \"CICLO1.Nuoto.01.IsolamentoAssetto\",\n      \"sport\": \"Nuoto in vasca\",\n      \"esercizi\": [\n        {\"descrizione\": \": :100: Riscaldamento - Stile Libero blando\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"100\", \"note\": \"Nuotata rilassata, focus sulla regolarità\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :25: Tecnico - Kick on Side (Gambe sul fianco)\", \"serie\": 4, \"um\": \"metri\", \"quantita\": \"25\", \"note\": \"Alternare fianco destro e sinistro ad ogni vasca\", \"recupero\": {\"serie\": 20, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :50: Centrale - Stile Libero con Pull Buoy\", \"serie\": 6, \"um\": \"metri\", \"quantita\": \"50\", \"note\": \"Isolamento core e respirazione bilaterale ogni 3 bracciate\", \"recupero\": {\"serie\": 30, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :100: Defaticamento - Dorso o Stile decontratto\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"100\", \"note\": \"Nuotata leggerissima per abbassare battiti\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}}\n      ]\n    },\n    {\n      \"nomeSessione\": \"CICLO1.Nuoto.02.ConsolidamentoFrazionato\",\n      \"sport\": \"Nuoto in vasca\",\n      \"esercizi\": [\n        {\"descrizione\": \": :100: Riscaldamento - Stile Libero alternato a Dorso\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"100\", \"note\": \"Attivazione generale e mobilità articolare\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :25: Tecnico - Sculling (Sensibilità acqua)\", \"serie\": 4, \"um\": \"metri\", \"quantita\": \"25\", \"note\": \"Isolare la presa della mano avanzata senza forzare\", \"recupero\": {\"serie\": 20, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :100: Centrale - Ripetute Stile Libero (Postura e Fiato)\", \"serie\": 4, \"um\": \"metri\", \"quantita\": \"100\", \"note\": \"Primi 25m Catch-Up Drill, successivi 50m completo decontratto\", \"recupero\": {\"serie\": 35, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :100: Defaticamento - Stile Libero rilassatissimo\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"100\", \"note\": \"Focus sullo scivolamento passivo idrodinamico\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}}\n      ]\n    },\n    {\n      \"nomeSessione\": \"CICLO1.GinnasticaACorpoLibero.01.HICT\",\n      \"sport\": \"Ginnastica a corpo libero\",\n      \"esercizi\": [\n        {\"descrizione\": \"A: 30: Plank frontale isometrico\", \"serie\": 2, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"Allineamento rigido testa-bacino-piedi per stabilità alto galleggiamento\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Squat a corpo libero\", \"serie\": 2, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Massimo ritmo controllato in spinta plantare simmetrica\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Lat Pulldown isometrico con asciugamano\", \"serie\": 2, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"Trazionare l'asciugamano verso l'esterno con massima forza continua\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Bird-Dog alternato\", \"serie\": 2, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Estensione fluida braccio/gamba opposta, stabilità lombare\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Piegamenti facilitati (ginocchia a terra)\", \"serie\": 2, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Gomiti stretti vicino ai fianchi per salvaguardare la spalla\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Mobilità spalle extra-rotatori con asciugamano\", \"serie\": 2, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"Tensione costante esterna per aprire il grande pettorale\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Plank laterale destro\", \"serie\": 2, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"Mantenere il fianco alto per allenare la stabilizzazione della rollata\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Plank laterale sinistro\", \"serie\": 2, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"Tenuta isometrica speculare per garantire simmetria posturale\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Ponte glutei a terra\", \"serie\": 2, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Attivazione glutei con picco contrattile di 1 secondo ad ogni rep\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Rematore isometrico con asciugamano sotto i piedi\", \"serie\": 2, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"Trazione continua massima tirando l'asciugamano, schiena dritta\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Superman short holds\", \"serie\": 2, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Sollevare petto e cosce da terra in modo controllato, hold 2s\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}},\n        {\"descrizione\": \"A: 30: Circonduzioni spalle lente con elastico\", \"serie\": 2, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Movimento di mobilità attiva molto lento e decontrattivo\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 90}}\n      ]\n    },\n    {\n      \"nomeSessione\": \"CICLO2.Nuoto.01.TransizionePropulsione\",\n      \"sport\": \"Nuoto in vasca\",\n      \"esercizi\": [\n        {\"descrizione\": \": :150: Riscaldamento - Stile Libero con focus rollata\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"150\", \"note\": \"Nuotare alternando la sensibilità sui due fianchi\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :50: Tecnico - 6-3-6 Drill (Cambio fianco)\", \"serie\": 4, \"um\": \"metri\", \"quantita\": \"50\", \"note\": \"Trovare la stabilità laterale prima delle 3 bracciate\", \"recupero\": {\"serie\": 20, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :100: Centrale - Frazionato di Resistenza Posturale\", \"serie\": 4, \"um\": \"metri\", \"quantita\": \"100\", \"note\": \"Mantenere una battuta di gambe a 2 tempi economica\", \"recupero\": {\"serie\": 30, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :150: Defaticamento - Dorso o Stile rilassato\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"150\", \"note\": \"Decontrarre spalle e allungare la sbracciata\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}}\n      ]\n    },\n    {\n      \"nomeSessione\": \"CICLO2.Nuoto.02.ConteggioBracciate\",\n      \"sport\": \"Nuoto in vasca\",\n      \"esercizi\": [\n        {\"descrizione\": \": :150: Riscaldamento - Stile Libero progressivo\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"150\", \"note\": \"Incremento graduale frequenza mantenendo allineamento\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :50: Tecnico - Catch-Up Drill alternato a Sculling\", \"serie\": 4, \"um\": \"metri\", \"quantita\": \"50\", \"note\": \"25m Sculling + 25m Stile sovrapposto\", \"recupero\": {\"serie\": 25, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :200: Centrale - Blocco di Scivolamento Idrodinamico\", \"serie\": 2, \"um\": \"metri\", \"quantita\": \"200\", \"note\": \"Contare le bracciate nella seconda vasca di ogni 50m per ridurle\", \"recupero\": {\"serie\": 40, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :150: Defaticamento - Nuotata blanda a piacere\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"150\", \"note\": \"Massimo relax muscolare subacqueo\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}}\n      ]\n    },\n    {\n      \"nomeSessione\": \"CICLO2.GinnasticaACorpoLibero.01.HICT\",\n      \"sport\": \"Ginnastica a corpo libero\",\n      \"esercizi\": [\n        {\"descrizione\": \"A: 30: Plank frontale dinamico (oscillazioni avanti/dietro)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Spostare il baricentro sulle punte mimando l'allungamento in sbracciata\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Affondi alternati posteriori\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Lavoro di stabilità monopodalica ed estensione dell'anca\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Lat Pulldown dinamico con elastico alle spalle\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Trazione fluida attivando i grandi dorsali e stabilizzando le scapole\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Bird-Dog statico tenuta isometrica alternata (15s+15s)\", \"serie\": 3, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"Mantenere una linea orizzontale perfetta senza oscillazioni del bacino\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Piegamenti classici sulle braccia\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Forza di spinta del cingolo scapolare. Mantenere l'addome compatto\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Aperture a busto flesso con elastico\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Rinforzo dei deltoidi posteriori per un recupero aereo alto\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Plank laterale destro con torsione del busto\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Ruotare il braccio libero sotto il costato e riallineare controllando il core\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Plank laterale sinistro con torsione del busto\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Esecuzione speculare per equilibrare la mobilità torsionale dei lati\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Ponte glutei monopodale (15s destro / 15s sinistro)\", \"serie\": 3, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"Massimo isolamento degli estensori dell'anca per l'assetto rettilineo\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Rematore dinamico busto flesso con elastico\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Simulazione dinamica della fase attiva di trazione (spinta finale)\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Nuotatore a terra (coordinazione braccia/gambe alternate)\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Movimenti alternati rapidi a pancia in giù, timing neuromuscolare\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}},\n        {\"descrizione\": \"A: 30: Stretching pettorali al muro in tenuta statica\", \"serie\": 3, \"um\": \"tempi\", \"quantita\": \"\", \"note\": \"Allungamento e decontrazione profonda dei muscoli intrarotatori\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 10, \"circuitoGiro\": 120}}\n      ]\n    },\n    {\n      \"nomeSessione\": \"CICLO3.Nuoto.01.CondizionamentoPacing\",\n      \"sport\": \"Nuoto in vasca\",\n      \"esercizi\": [\n        {\"descrizione\": \": :200: Riscaldamento - Stile Libero sciolto\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"200\", \"note\": \"Concentrazione sul ritmo respiratorio calmo\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :100: Tecnico - Esercizi misti di sensibilità (Drills)\", \"serie\": 2, \"um\": \"metri\", \"quantita\": \"100\", \"note\": \"50m 6-3-6 + 50m Catch-Up\", \"recupero\": {\"serie\": 20, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :600: Centrale - Piramide di Condizionamento Energetico\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"600\", \"note\": \"Frazionato come 100m+200m+200m+100m a ritmo gara CSS\", \"recupero\": {\"serie\": 30, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :200: Defaticamento - Dorso rilassato\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"200\", \"note\": \"Fase finale di rilassamento muscolare completo\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}}\n      ]\n    },\n    {\n      \"nomeSessione\": \"CICLO3.Nuoto.02.TestFinaleContinuo\",\n      \"sport\": \"Nuoto in vasca\",\n      \"esercizi\": [\n        {\"descrizione\": \": :100: Riscaldamento - Stile Libero e attivazione\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"100\", \"note\": \"Attivazione cardiaca minima senza accumulo lattato\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :50: Tecnico - Sculling controllato\", \"serie\": 2, \"um\": \"metri\", \"quantita\": \"50\", \"note\": \"Svegliare i recettori nervosi del palmo della mano\", \"recupero\": {\"serie\": 15, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :1000: Centrale - TEST 1.000 METRI CONTINUI\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"1000\", \"note\": \"Nuotata continua. Focus sul non accelerare nei primi 200 metri\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}},\n        {\"descrizione\": \": :50: Defaticamento - Nuotata leggerissima a piacere\", \"serie\": 1, \"um\": \"metri\", \"quantita\": \"50\", \"note\": \"Scarico totale decontrattivo post-test\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": null, \"circuitoGiro\": null}}\n      ]\n    },\n    {\n      \"nomeSessione\": \"CICLO3.GinnasticaACorpoLibero.01.HICT\",\n      \"sport\": \"Ginnastica a corpo libero\",\n      \"esercizi\": [\n        {\"descrizione\": \"A: 30: Plank sulle mani con tocco spalla alternato\", \"serie\": 3, \"um\": \"n.\", \"quantita\": \"\", \"note\": \"Stabilizzazione del core in condizione di instabilità asimmetrica\", \"recupero\": {\"serie\": null, \"esercizio\": null, \"circuitoInterno\": 6, \"circuitoGiro\": 90}},\n        {\"